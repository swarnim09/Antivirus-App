<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F3F4F6">

    <!-- Toolbar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:background="#1A237E">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="App Permission Checker"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold"/>

        <TextView
            android:id="@+id/tvCount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Loading..."
            android:textColor="#90CAF9"
            android:textSize="13sp"/>
    </LinearLayout>

    <!-- Search Bar -->
    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="12dp"
        app:cardCornerRadius="8dp"
        app:cardElevation="2dp">

        <EditText
            android:id="@+id/etSearch"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:hint="🔍  Search apps..."
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:background="@null"
            android:inputType="text"
            android:singleLine="true"/>
    </com.google.android.material.card.MaterialCardView>

    <!-- Risk Legend -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingBottom="8dp"
        android:gravity="center_vertical">

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Risk: " android:textColor="#757575" android:textSize="12sp"/>
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="● HIGH " android:textColor="#D32F2F" android:textSize="12sp"/>
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="● MED " android:textColor="#F57C00" android:textSize="12sp"/>
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="● LOW " android:textColor="#FBC02D" android:textSize="12sp"/>
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="● SAFE" android:textColor="#388E3C" android:textSize="12sp"/>
    </LinearLayout>

    <!-- Apps RecyclerView -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvApps"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingBottom="12dp"
        android:clipToPadding="false"/>

</LinearLayout>
